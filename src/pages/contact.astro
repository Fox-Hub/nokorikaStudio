---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Bi from '../components/Bi.astro';
---
<Layout
  title="お問い合わせ｜Nokorika Studio"
  titleEn="Contact｜Nokorika Studio"
  description="Nokorika Studioへのお問い合わせはこちらから。"
  descriptionEn="Get in touch with Nokorika Studio."
>
  <Header slot="header" />

  <section class="contact">
    <div class="wrap contact-grid">
      <div>
        <p class="eyebrow">CONTACT</p>
        <h1><Bi ja="お問い合わせ" en="Contact" /></h1>
        <p class="body-text">
          <Bi
            ja="サービスに関するご質問・取材のご依頼などは、以下のメールアドレスまでご連絡ください。内容を確認のうえ、担当者より折り返しご連絡いたします。"
            en="For questions about our service or media inquiries, please contact us at the email address below. We'll review your message and get back to you."
          />
        </p>
      </div>

      <div class="card">
        <dl>
          <div class="row">
            <dt class="mono">Email</dt>
            <dd><a href="contact@nokorikastudio.com">contact@nokorikastudio.com</a></dd>
          </div>
          <div class="row">
            <dt class="mono"><Bi ja="対応時間" en="Hours" /></dt>
            <dd><Bi ja="平日 10:00–18:00（土日祝を除く）" en="Weekdays 10:00–18:00 (JST), excluding holidays" /></dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <Footer slot="footer" />

  <style>
    .contact {
      padding-top: clamp(56px, 9vw, 88px);
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(32px, 6vw, 64px);
      align-items: start;
    }
    h1 {
      font-size: clamp(1.8rem, 3.4vw, 2.3rem);
      margin: 10px 0 16px;
    }
    .body-text {
      color: var(--ink-soft);
      max-width: 46ch;
    }
    .card {
      background: var(--paper-raised);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 28px;
    }
    .row {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 16px;
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }
    .row:last-child {
      border-bottom: none;
    }
    dt {
      color: var(--ink-soft);
      font-size: 0.8rem;
    }
    dd {
      margin: 0;
    }
    dd a {
      color: var(--accent);
      text-decoration: underline;
    }
    .note {
      margin-top: 18px;
      font-size: 0.78rem;
      color: var(--ink-soft);
    }
    @media (max-width: 720px) {
      .contact-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
