---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Bi from '../components/Bi.astro';

const faqs = [
  {
    q: { ja: 'アプリはいつリリースされますか？', en: 'When will the app be released?' },
    a: {
      ja: '現在製品版のリリースに向けて最終調整を行っております。Google Playストアでの公開日が決定次第、このサイトのトップページやアップデート情報にてお知らせいたします。',
      en: "We are currently in the final stages of adjustment for the official release. As soon as the launch date on the Google Play Store is confirmed, we will announce it on the top page of this website and in our update news.",
    },
  },
  {
    q: { ja: '対応しているOS・バージョンを教えてください。', en: 'Which OS versions are supported?' },
    a: {
      ja: 'Android 10.0 以降のスマートフォンに対応しています。※一部の特殊な画面比率の端末や、非常に古いエントリーモデルの端末ではレイアウトが最適化されない場合があります。最新のエミュレータ（Pixel 7等）にて動作検証を行っております。',
      en: 'The app supports smartphones running Android 10.0 or later. Please note that layout adjustments may not be fully optimized for certain devices with unique screen aspect ratios or older entry-level models. We continuously test and verify performance using the latest emulators (such as Pixel 7).',
    },
  },
  {
    q: { ja: '料金はかかりますか？', en: 'Is there a fee to use the app?' },
    a: {
      ja: '基本機能（カレンダー表示、週間バーティカルタイムライン、タスク・Todo管理機能）はすべて完全無料でご利用いただけます。アプリ内課金や強制的なポップアップ広告なども一切ありませんので、安心してお使いください。',
      en: 'No, the core features (Calendar view, Weekly vertical timeline, and Task/Todo management) are completely free to use. There are no in-app purchases or forced pop-up ads, so you can use it with peace of mind.',
    },
  },
  {
    q: { ja: '不具合を見つけました。どこに報告すればいいですか？', en: 'I found a bug — where do I report it?' },
    a: {
      ja: 'アプリのご利用中に動かなくなったり、表示が崩れたりする不具合を発見された場合は、大変お手数ですが、以下のサポート窓口（メールアドレス）までご連絡ください。発生状況（端末の種類・OSバージョン・操作手順）を添えていただけるとスムーズです。',
      en: "If you encounter any bugs, crashes, or display issues while using the app, we apologize for the inconvenience and kindly ask you to contact our support desk at the following email. It helps if you include details like your device type, OS version, and the steps that led to the issue.",
    },
  },
  {
    q: { ja: '予定データはどこに保存されますか？バックアップはできますか？', en: 'Where is my event data stored? Can I back it up?' },
    a: {
      ja: '入力された予定やTodoタスクのデータは、外部のサーバーではなく、お使いのスマートフォン端末内の安全な領域（ローカルストレージ）にのみ保存されます。そのため、オフライン（電波の届かない場所）でも高速に動作します。なお、現時点ではクラウド同期機能は搭載されていないため、アプリを完全に削除（アンインストール）するとデータも消去されますのでご注意ください。',
      en: 'All your entered schedules and Todo tasks are stored exclusively on your local device storage and are never sent to external servers. Because of this, the app operates fast and works completely offline. Please note that a cloud sync feature is currently not supported; if you uninstall or delete the app, your data will be permanently removed.',
    },
  },
  {
    q: { ja: '要望や機能追加のリクエストは受け付けていますか？', en: 'Can I request a new feature?' },
    a: {
      ja: 'はい、大歓迎です！「こんな機能が欲しい」「ここをもう少し改善してほしい」といったアイデアがございましたら、上記のサポート窓口メールアドレスまでお気軽にお寄せください。個人開発のフットワークの軽さを活かし、ユーザーの皆様にとって最高のスケジュール帳になるよう、今後のアップデートの参考にさせていただきます。',
      en: "Yes, we absolutely welcome them! If you have any ideas like 'I wish there was a feature like this' or 'I want this part improved,' please feel free to drop us a line at our support email address above. As an independent developer, we love taking quick action on user feedback to create the best possible digital planner. Your suggestions will be highly valued for future updates!",
    },
  },
];
---
<Layout
  title="サポート / FAQ｜Nokorika Studio"
  titleEn="Support / FAQ｜Nokorika Studio"
  description="Nokorika Studioが提供するアプリに関するサポート情報・よくある質問です。"
  descriptionEn="Support information and frequently asked questions about the app developed by Nokorika Studio."
>
  <Header slot="header" />

  <section class="support-intro">
    <div class="wrap intro-grid">
      <div data-reveal>
        <p class="eyebrow">SUPPORT</p>
        <h1><Bi ja="サポート / FAQ" en="Support / FAQ" /></h1>
        <p class="body-text">
          <Bi
            ja="アプリのご利用に関するご質問・不具合のご報告は、以下のメールアドレスまでご連絡ください。よくいただくご質問はこのページにまとめています。"
            en="For questions about using the app or to report a bug, please contact us at the email address below. Common questions are listed on this page."
          />
        </p>
      </div>
      <div class="card hover-lift" data-reveal>
        <dl>
          <div class="row">
            <dt class="mono">Email</dt>
            <dd><a href="mailto:contact@nokorikastudio.com">contact@nokorikastudio.com</a></dd>
          </div>
          <div class="row">
            <dt class="mono"><Bi ja="対応時間" en="Hours" /></dt>
            <dd><Bi ja="平日 10:00–18:00（土日祝を除く）" en="Weekdays 10:00–18:00 (JST), excluding holidays" /></dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="faq">
    <div class="wrap">
      <p class="eyebrow">FAQ</p>
      <h2 data-reveal><Bi ja="よくあるご質問" en="Frequently Asked Questions" /></h2>

      <ul class="faq-list" data-reveal="stagger">
        {faqs.map((item) => (
          <li>
            <p class="q"><span class="mono mark">Q</span><Bi ja={item.q.ja} en={item.q.en} /></p>
            <p class="a"><span class="mono mark">A</span><Bi ja={item.a.ja} en={item.a.en} /></p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Footer slot="footer" />

  <style>
    .support-intro {
      padding-top: clamp(56px, 9vw, 88px);
    }
    .intro-grid {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(32px, 6vw, 64px);
      align-items: start;
    }
    h1 {
      font-size: clamp(1.8rem, 3.4vw, 2.3rem);
      margin: 10px 0 16px;
    }
    .body-text {
      color: var(--ink-soft);
      max-width: 46ch;
    }
    .card {
      background: var(--paper-raised);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 28px;
    }
    .row {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 16px;
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }
    .row:last-child {
      border-bottom: none;
    }
    dt {
      color: var(--ink-soft);
      font-size: 0.8rem;
    }
    dd {
      margin: 0;
    }
    dd a {
      color: var(--accent);
      text-decoration: underline;
    }
    .note {
      margin-top: 18px;
      font-size: 0.78rem;
      color: var(--ink-soft);
    }

    .faq h2 {
      font-size: clamp(1.4rem, 2.6vw, 1.9rem);
      margin: 10px 0 28px;
    }
    .faq-list {
      list-style: none;
      margin: 0;
      padding: 0;
      border-top: 1px solid var(--line);
    }
    .faq-list li {
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
    }
    .q,
    .a {
      display: flex;
      gap: 12px;
      margin: 0;
      line-height: 1.8;
    }
    .q {
      font-weight: 600;
      margin-bottom: 8px;
    }
    .a {
      color: var(--ink-soft);
    }
    .mark {
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      width: 22px;
      height: 22px;
      border-radius: 6px;
      font-size: 0.75rem;
      background: var(--status-bg);
      color: var(--status);
    }
    .q .mark {
      background: var(--accent);
      color: var(--accent-ink);
    }

    @media (max-width: 720px) {
      .intro-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
